FLASK_ENV=development
FLASK_DEBUG=1

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING

# ── MongoDB ─────────────────────────────────────────────────────────────────
# Option A – MongoDB Atlas (cloud, free tier):
#   1. Go to https://www.mongodb.com/atlas and create a free cluster
#   2. Database Access → create user (e.g. noteuser / yourpassword)
#   3. Network Access → Add IP Address → Allow Access from Anywhere (dev only)
#   4. Connect → Drivers → copy the SRV URI and replace below:
# MONGO_URI=mongodb+srv://noteuser:yourpassword@cluster0.xxxxx.mongodb.net/academic_notes_db?retryWrites=true&w=majority
#
# Option B – Local MongoDB (if MongoDB Community is installed):
MONGO_URI=mongodb://localhost:27017/academic_notes_db

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING
JWT_ACCESS_TOKEN_EXPIRES=86400

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys (requires GPT-4 access)
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# ── File Upload ──────────────────────────────────────────────────────────────
MAX_CONTENT_LENGTH=20971520
UPLOAD_FOLDER=uploads

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
